{
  "name": "obsidian-mini-calendar",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "tsc --noEmit",
    "check:metadata": "node scripts/check-release-metadata.mjs",
    "lint": "eslint src --max-warnings=0",
    "test": "node scripts/test.mjs",
    "verify": "npm run check:metadata && npm run check && npm run lint && npm run test && npm run build",
    "package": "node scripts/package-release.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
